# Copy to .env and adjust. Never commit .env.

# ---- app ----
APP_NAME=aadhaar-face-verify
ENV=dev
LOG_LEVEL=INFO

# ---- server ----
HOST=0.0.0.0
PORT=8000

# ---- cors (comma-separated origins; empty disables CORS) ----
CORS_ORIGINS=http://localhost:8000

# ---- api auth (comma-separated keys; empty disables auth in dev) ----
API_KEYS=

# ---- redis ----
REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=600

# =========================================================
# Aadhaar / Passport Face Verification Production Config
# Optimized for Low-Quality Documents + Live Webcam
# =========================================================

# ---------------------------------------------------------
# Upload / API Limits
# ---------------------------------------------------------

MAX_UPLOAD_BYTES=7340032
MAX_FRAMES=25
MAX_FRAME_BYTES=1572864

RATE_LIMIT_UPLOAD=12/minute
RATE_LIMIT_VERIFY=25/minute


# ---------------------------------------------------------
# Face Engine
# ---------------------------------------------------------

DET_SIZE=640
USE_GPU=true

FACE_DETECTOR=retinaface
FACE_RECOGNITION_MODEL=adaface

ENABLE_FACE_ALIGNMENT=true
ENABLE_MULTI_FACE_REJECTION=true


# ---------------------------------------------------------
# Verification Thresholds
# Tuned for Aadhaar / Passport / Age Gap
# ---------------------------------------------------------

BASE_VERIFIED=0.68
BASE_REVIEW=0.56

MAX_RELAX=0.08
RELAX_PER_YEAR=0.004

HIGH_CONFIDENCE=0.78
HARD_REJECT=0.45


# ---------------------------------------------------------
# Aadhaar / Document Quality Gate
# ---------------------------------------------------------

MIN_FACE_PX=72
MIN_DET_SCORE=0.65

BLUR_VAR_WARN=45.0
BLUR_VAR_REJECT=28.0

BLUR_NORM_WIDTH=224

MIN_BRIGHTNESS=55
MAX_BRIGHTNESS=220

ENABLE_DOCUMENT_ENHANCEMENT=true
ENABLE_SUPER_RESOLUTION=true


# ---------------------------------------------------------
# Liveness Detection
# ---------------------------------------------------------

TURN_DELTA=0.18
NOD_DELTA=0.09

CLOSER_RATIO=1.20

FRONTAL_YAW=0.15

MIN_FACE_FRAMES=0.70


# ---------------------------------------------------------
# Blink Detection
# ---------------------------------------------------------

ENABLE_BLINK_CHECK=true

EAR_THRESHOLD=0.21
MIN_BLINK_FRAMES=2
REQUIRED_BLINKS=1


# ---------------------------------------------------------
# Pose Validation
# ---------------------------------------------------------

MAX_YAW=20
MAX_PITCH=18
MAX_ROLL=20


# ---------------------------------------------------------
# Motion / Replay Protection
# ---------------------------------------------------------

ENABLE_MOTION_ANALYSIS=true
MOTION_THRESHOLD=1.8

ENABLE_TEXTURE_ANALYSIS=true
ENABLE_GLARE_CHECK=true
ENABLE_MOIRE_DETECTION=true

ALLOW_SCREEN_RECAPTURE=false
ALLOW_PRINTED_FACE=false


# ---------------------------------------------------------
# Multi-frame Verification
# ---------------------------------------------------------

TOTAL_CAPTURE_FRAMES=15
MIN_GOOD_FRAMES=8

ENABLE_FRAME_QUALITY_FILTER=true
ENABLE_EMBEDDING_AVERAGING=true

EMBEDDING_AVG_COUNT=5


# ---------------------------------------------------------
# Enhancement Pipeline
# ---------------------------------------------------------

ENABLE_CODEFORMER=true
ENABLE_REALESRGAN=true

CODEFORMER_FIDELITY=0.7
REALESRGAN_SCALE=2


# ---------------------------------------------------------
# Observability
# ---------------------------------------------------------

METRICS_ENABLED=true

AUDIT_LOG_PATH=/var/log/aadhaar-verify/audit.log

SAVE_FAILED_ATTEMPTS=true
SAVE_SPOOF_EVENTS=true


# ---------------------------------------------------------
# Security
# ---------------------------------------------------------

ENABLE_DEVICE_FINGERPRINT=true
ENABLE_IP_RATE_LIMIT=true

ALLOW_MULTIPLE_FACES=false
REJECT_MASKED_FACE=true

STRICT_LIVENESS_MODE=true