# Copy to .env and adjust. Never commit .env.

# ---- app ----
APP_NAME=aadhaar-face-verify
ENV=dev
LOG_LEVEL=INFO

# ---- server ----
HOST=0.0.0.0
PORT=8001

# ---- cors (comma-separated origins; empty disables CORS) ----
CORS_ORIGINS=http://localhost:8001

# ---- api auth (comma-separated keys; empty disables auth in dev) ----
API_KEYS=

# ---- redis ----
REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=600

# ---- limits ----
MAX_UPLOAD_BYTES=5242880
MAX_FRAMES=40
MAX_FRAME_BYTES=1048576
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_VERIFY=20/minute

# ---- face engine ----
DET_SIZE=640
USE_GPU=false

# ---- verify thresholds (CALIBRATE on your own data) ----
# Generic fallback when no per-doc band matches
PCT_VERIFIED=75.0
PCT_REVIEW=50.0
PCT_MAX_RELAX=10.0
PCT_RELAX_PER_YEAR=0.5

# Per-document bands (percentage points). Values match the safe-values spec.
AADHAAR_VERIFY_PCT=46.0
AADHAAR_REVIEW_PCT=43.0
PAN_VERIFY_PCT=52.0
PAN_REVIEW_PCT=49.0
DL_VERIFY_PCT=56.0
DL_REVIEW_PCT=53.0
VOTER_VERIFY_PCT=43.0
VOTER_REVIEW_PCT=40.0
PASSPORT_VERIFY_PCT=63.0
PASSPORT_REVIEW_PCT=50.0

# Legacy cosine-space thresholds (kept for the legacy decide() path)
BASE_VERIFIED=0.50
BASE_REVIEW=0.36
MAX_RELAX=0.10
RELAX_PER_YEAR=0.005

# ---- aadhaar quality gate ----
MIN_FACE_PX=48
MIN_DET_SCORE=0.50
BLUR_VAR_WARN=12.0
BLUR_NORM_WIDTH=160

# ---- liveness deltas ----
TURN_DELTA=0.18
NOD_DELTA=0.12
CLOSER_RATIO=1.22
FRONTAL_YAW=0.12
MIN_FACE_FRAMES=0.55

# ---- observability ----
METRICS_ENABLED=true
AUDIT_LOG_PATH=/var/log/aadhaar-verify/audit.log
